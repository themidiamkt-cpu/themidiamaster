# Google Ads API
# Obtenha em: https://developers.google.com/google-ads/api/docs/get-started/dev-token
GOOGLE_ADS_DEVELOPER_TOKEN=seu_developer_token_aqui

# OAuth 2.0 — crie em https://console.cloud.google.com/apis/credentials
GOOGLE_ADS_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=seu_client_secret

# Refresh token gerado via OAuth 2.0 para a conta que tem acesso ao Google Ads
GOOGLE_ADS_REFRESH_TOKEN=seu_refresh_token

# ID da conta MCC (manager), sem tracoes. Deixe vazio se for conta direta.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Supabase Edge Function: sync-meta-ads-daily
# Configure como secrets no Supabase, nao no frontend.
META_ACCESS_TOKEN=seu_token_meta_ads
# O Supabase geralmente fornece SUPABASE_SERVICE_ROLE_KEY automaticamente.
# Se precisar cadastrar manualmente, use SERVICE_ROLE_KEY porque o prefixo SUPABASE_ e reservado.
SERVICE_ROLE_KEY=sua_service_role_key_do_supabase
CRON_SECRET=um_segredo_para_backfill_manual
